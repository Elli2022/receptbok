# Supabase (krävs för recept + auth via Next API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Använd anon-nyckeln från Supabase Dashboard → Project Settings → API.
# Nyare projekt kan visa "publishable key"; samma värde funkar som anon om du bara sätter ett av fälten nedan:
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Endast server (Netlify / .env.local) — aldrig NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Valfritt: gammal Express-proxy (används inte om Supabase är konfigurerad ovan)
# NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
# BACKEND_URL=

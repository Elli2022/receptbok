# Optional if you want to sync recipes to the existing Express backend.
# Without this, the app still works with local recipes and saved favorites.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Use this on Netlify instead of NEXT_PUBLIC_BACKEND_URL if you do not want
# the backend address exposed in client-side bundles.
BACKEND_URL=https://your-backend.example.com
